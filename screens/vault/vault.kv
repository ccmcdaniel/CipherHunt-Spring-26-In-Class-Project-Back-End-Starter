#:kivy 1.0
#:import utils kivy.utils

<VaultScreen>:

    BoxLayout:
        padding: 5
        orientation: 'vertical'
        padding: 17
        spacing: 5

        ContentBox:
            title_text: "[b][size=32sp]Created By:[/size]\n[size=20sp]{???}, {???}[/size][/b]"

            BoxLayout:
                orientation: 'vertical'            
                padding: [10]
                spacing: 20

                Label:
                    text: "Riddle Text"
                    text_size: (self.width, None)
                    halign: 'center'
                    valign: 'middle'
                    color: utils.get_color_from_hex("#ffffff")
                    font_size: '36sp'

                TextBox:
                    hint_text: "Answer"
                
                AppButton:
                    text: "Submit"
                AppButton:
                    text: "Fetch Clue"

        Label:
            color: utils.get_color_from_hex("#000000")
            font_size: '24sp'
            valign: 'middle'
            padding: [20] if self.text != '' else [0]
            text_size: self.size
            halign: 'center'

            size_hint: (1, None)
            height: self.texture_size[1] if self.text != '' else 0        
