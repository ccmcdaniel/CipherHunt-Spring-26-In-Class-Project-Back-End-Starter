#:kivy 1.0
#:import utils kivy.utils

<LabScreen>:

    BoxLayout:
        padding: 5
        orientation: 'vertical'
        padding: 17
        spacing: 5

        ContentBox:
            title_text: f"[b][size=32sp]Create New Clue[/size][/b]"

            BoxLayout:
                orientation: 'vertical'            
                padding: [10]
                spacing: 20


                TextBox:
                    is_multiline: True
                    hint_text: "What is your clue?"

                TextBox:
                    id: txtKeyInput
                    hint_text: "Enter Key Here..."
                
                AppButton:
                    text: "Create"

        Label:
            color: utils.get_color_from_hex("#FF0000")
            font_size: '24sp'
            valign: 'middle'
            padding: [20] if self.text != '' else [0]
            text_size: self.size
            halign: 'center'

            size_hint: (1, None)
            height: self.texture_size[1] if self.text != '' else 0

        
